{
  "name": "@sublang/slc",
  "version": "0.1.0",
  "description": "SubLang Compiler (slc): runs phase pipelines.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sublang-ai/slc.git"
  },
  "homepage": "https://github.com/sublang-ai/slc#readme",
  "bugs": {
    "url": "https://github.com/sublang-ai/slc/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "compiler",
    "playbook",
    "state-machine"
  ],
  "type": "module",
  "bin": {
    "slc": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./verify": {
      "types": "./dist/verify.d.ts",
      "default": "./dist/verify.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=23.6"
  },
  "scripts": {
    "build": "tsc && cp src/normalize.md src/slc.config.template.yaml dist/",
    "test": "vitest run",
    "test:package": "node scripts/test-package.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:definitions": "node scripts/verify-playbook-definitions.mjs",
    "verify:release": "node scripts/verify-release-workflow.mjs",
    "verify:artifacts": "node scripts/verify-artifacts.mjs pipelines/playbook/text2gears.slc text2gears && node scripts/verify-artifacts.mjs pipelines/playbook/gears2fsm.slc gears2fsm && node scripts/verify-artifacts.mjs pipelines/playbook/link.slc link",
    "verify:pins": "node scripts/generate-pins.mjs && git diff --exit-code -- pipelines/playbook/slc.pins.json",
    "verify:demo": "node demo/reference/check.mjs en",
    "release:check": "npm run format:check && npm run lint && npm run build && npm test && npm run verify:definitions && npm run verify:release && npm run verify:artifacts && npm run verify:pins && npm run verify:demo && npm run test:package",
    "prepublishOnly": "npm run release:check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "p-queue": "^9.3.1",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@sublang/cligent": "^0.16.0",
    "@sublang/playbook": "^2.0.0",
    "@sublang/spex": "^0.3.0",
    "typescript": "^6.0.3",
    "xstate": "^5.32.4",
    "yaml": "^2.9.0"
  }
}
