{
  "name": "@sublang/slc",
  "version": "0.0.0",
  "description": "SubLang Compiler (slc): runs phase pipelines.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "slc": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./verify": {
      "types": "./dist/verify.d.ts",
      "default": "./dist/verify.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=23.6"
  },
  "scripts": {
    "build": "tsc && cp src/normalize.md src/slc.config.template.yaml dist/",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:definitions": "node scripts/verify-playbook-definitions.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "p-queue": "^9.3.1",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@sublang/cligent": "^0.16.0",
    "@sublang/playbook": "^2.0.0",
    "@sublang/spex": "^0.3.0",
    "typescript": "^6.0.3",
    "xstate": "^5.32.4",
    "yaml": "^2.9.0"
  }
}
